# 本地环境配置（与系统环境变量等价）
# 使用：复制本文件为同目录下的 env.properties（不要提交 env.properties）
# 启动时由 application.yml 通过 spring.config.import 自动加载

# 数据库（对应 application.yml 中的 ${PM_DB_URL} 等）
PM_DB_URL=jdbc:mysql://localhost:3306/pm_system?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai
PM_DB_USERNAME=root
PM_DB_PASSWORD=123456

# JWT（可选，不配置则使用 application.yml 默认值）
# PM_SECURITY_JWT_SECRET=请使用 Base64 编码的足够长的密钥
# PM_SECURITY_JWT_EXPIRE_SECONDS=7200

# 服务端口（可选）
# SERVER_PORT=8080
